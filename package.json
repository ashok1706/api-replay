{
  "name": "api-replay",
  "version": "1.0.0",
  "description": "Record real API traffic, replay it anywhere, and instantly spot what changed",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "files": [
    "src/**/*.js",
    "src/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "api-replay": "./src/cli/index.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "api",
    "replay",
    "record",
    "diff",
    "express",
    "middleware",
    "debugging",
    "testing",
    "mock",
    "traffic",
    "http",
    "request",
    "response"
  ],
  "author": "",
  "repository": {
    "type": "git",
    "url": ""
  },
  "homepage": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  }
}
